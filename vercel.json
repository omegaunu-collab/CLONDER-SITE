{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/",
      "destination": "/naddict.com/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/naddict.com/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/products/nadpulse-pen-kit-1.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/products/nadpulse-pen-kit-1",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/naddict.com/:path*",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ]
}
